# Scenario 03 — YOLOv5n at 416×416 with active FPS halved to 3 Hz.
#
# This is the audit's recommended "if YOLO at all" configuration:
#   - Active FPS 3 Hz instead of 5 Hz lowers GPU duty cycle ~40 %.
#   - Idle FPS unchanged at 1 Hz.
#
# Same engine pre-build prerequisite as 02-yolo-416.
DETECT_MODEL=yolov5n
DETECT_ACTIVE_FPS=3.0
DETECT_IDLE_FPS=1.0
