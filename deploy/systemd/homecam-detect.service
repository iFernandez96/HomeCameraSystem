[Unit]
Description=Home Camera detection worker (jetson-inference)
Requires=mediamtx.service
After=mediamtx.service homecam-server.service
Wants=homecam-server.service
# Restart-storm guard: if the worker fails 5 times within 60 s (i.e. an
# unrecoverable bug like a Python syntax error or a missing module),
# systemd stops auto-restarting and surfaces the failure rather than
# spinning the cgroup at 100 %. iter-28's `from __future__ import
# annotations` (Py 3.7+ syntax on the 3.6 host) hit ~42 restarts in
# seconds before someone noticed; this clamps that.
StartLimitBurst=5
StartLimitIntervalSec=60

[Service]
# iter (camera-recovery 2026-06-20): sd_notify Type=notify + WatchdogSec was
# attempted here but DEFERRED — on the live worker, READY=1 was accepted yet
# the per-loop WATCHDOG=1 pings did not refresh the systemd watchdog timer
# (WatchdogTimestamp never advanced past READY), so WatchdogSec kept firing and
# restart-cycled the worker. Root cause still under investigation (likely the
# `_latest.jpg` saver runs in a side thread while the ping sits on a slower
# path, or a NOTIFY_SOCKET reuse quirk). The escalating mediamtx_watchdog +
# BindsTo + the GStreamer watchdog element already cover the real failure
# modes; the systemd liveness watchdog is belt-and-suspenders for a TRUE
# worker hang and will be re-enabled once the ping path is verified. The
# detect.py sd_notify calls are no-ops while NOTIFY_SOCKET is unset (Type=simple).
Type=simple
User=israel
Group=israel
# `video` is required for jetson-utils' `videoSource` to open NVDEC for
# H.264 decode of the MediaMTX RTSP stream. Removing this group breaks the
# capture path with EACCES on /dev/nvhost-* nodes.
SupplementaryGroups=video
WorkingDirectory=/home/israel/HomeCameraSystem
Environment=EVENT_URL=http://127.0.0.1:8000/api/_internal/event
Environment=DETECT_SOURCE=rtsp://localhost:8554/cam
Environment=DETECT_THRESHOLD=0.55
Environment=DETECT_COOLDOWN_S=5.0
Environment=DETECT_MODEL=ssd-mobilenet-v2
ExecStart=/home/israel/HomeCameraSystem/detection/run-detect.sh
Restart=on-failure
RestartSec=5
# nvarguscamerasrc/jetson-utils touches /tmp; don't enable PrivateTmp (same
# trap mediamtx.service hit — see deploy/systemd/mediamtx.service).
#
# iter-356.63 (camera-recovery sharp edge): NoNewPrivileges INTENTIONALLY
# REMOVED. The iter-302 auto-recovery (`escalate_argus_recovery` in
# detect.py:493) shells `sudo -n systemctl restart {nvargus-daemon,
# mediamtx}` when the libargus broker wedges. With NNP=yes the kernel
# blocks setuid elevation in this unit's process group; sudo fails with
# the misleading "is /usr/bin/sudo on a file system with the 'nosuid'
# option set" error and the auto-recovery silently drops — the live
# feed stays broken until an operator SSHes in. Defense-in-depth cost
# of dropping NNP is small: `israel ALL NOPASSWD: ALL` is already on
# the host (see /etc/sudoers.d), so any process that can replace this
# unit's binary already has full root via that path. The defense bar
# is "user israel doesn't get tricked into running foreign code under
# this unit," not "this unit is sandboxed."

[Install]
WantedBy=multi-user.target
