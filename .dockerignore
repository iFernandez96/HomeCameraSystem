# Trim what `docker compose build` ships to the daemon. The compose
# context is the repo root (deploy/docker-compose.yml has `context:
# ..`), so anything left in here ends up transferred over the
# loopback or — worse, on the Jetson — over the SD-card I/O.
#
# Biggest single win: client/node_modules is ~5.5 GB and never lands
# in the image (the server serves client/dist/ via the docker-compose
# bind mount, not from inside the image). Excluding it cuts the
# context transfer from minutes-per-build to seconds.

# Whole subtrees the server image doesn't need.
client/
detection/

# Claude / project memory.
memory/
.claude/

# VCS.
.git
.gitignore
.gitattributes

# Python build / cache artefacts (anywhere in the tree).
**/__pycache__/
**/*.pyc
**/*.pyo
**/.pytest_cache/
**/*.egg-info/
**/.mypy_cache/
**/.ruff_cache/

# Server-side test tree — copied INTO the image by `COPY server/ ./`
# but never run there (pytest isn't a runtime dep). Excluding saves
# ~10 MB and avoids shipping CI artefacts to prod.
server/tests/

# Editor / OS scratch.
.vscode/
.idea/
*.swp
*~
.DS_Store

# Any local Python venv someone left around.
**/.venv/
**/venv/

# Snapshots dir is created by the runtime; the build doesn't need it
# (and it could hold months of personal images).
snapshots/
recordings/
backups/
timelapses/
face_captures/
person_captures/

# Local proof fixtures / fetched Jetson data. Never needed in the server image
# and can be hundreds of MB, making deploys crawl.
.jetson-snapshot/

# Pre-built MediaMTX binary — installed by deploy/install-jetson.sh,
# not by the Docker image.
mediamtx
