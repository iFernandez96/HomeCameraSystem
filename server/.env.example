# Server bind
HOST=0.0.0.0
PORT=8000

# Direct host-worker authentication. The secret is provisioned on the Jetson
# and bind-mounted read-only into the server container; never place its value
# in this environment file.
HOMECAM_WORKER_AUTH_FILE=/run/secrets/homecam-worker-auth
HOMECAM_WORKER_AUTH_TRUSTED_CALLERS=127.0.0.1,::1,172.30.0.1

# VAPID keys (generated by `python -m app.scripts.gen_vapid`)
VAPID_PRIVATE_KEY_PATH=./vapid_private.pem
VAPID_PUBLIC_KEY_PATH=./vapid_public.pem
VAPID_SUBJECT=mailto:admin@example.com

# Camera
CAMERA_DEVICE=/dev/video0

# Camera registry (docs/multicam_contract.md, 2026-07-07): JSON array
# of {"id","name","path"} objects. `id` must match ^[a-z0-9_]{1,32}$;
# `path` is the MediaMTX base path the quality rungs derive from.
# Unset (or invalid — logged at WARNING) falls back to the default
# single-camera registry shown below.
HOMECAM_CAMERAS=[{"id":"front_door","name":"Front Door","path":"cam"}]

# Compiled client to serve as SPA (relative to server/ working dir)
CLIENT_DIST=../client/dist

# Snapshot output
SNAPSHOTS_DIR=./snapshots

# iter-201 (Feature #1 Event clip recording): on-disk dir for per-
# event MP4 clips written by the host-side recorder (slice 2).
# Bind-mounted similarly to SNAPSHOTS_DIR so the host writes /
# the container reads. The iter-201 sweeper deletes clips older
# than RECORDINGS_RETENTION_DAYS; default 14 days. Set to 0 to
# disable the sweeper (operator manages retention manually).
RECORDINGS_DIR=./recordings
RECORDINGS_RETENTION_DAYS=14
# MediaMTX continuous fMP4 archive: <root>/<camera path>/<unix-seconds>.mp4.
CONTINUOUS_RECORDINGS_DIR=./recordings/continuous

# Persisted Web Push subscriptions. In production this lives on the
# `homecam-secrets` Docker volume so it survives container rebuilds.
PUSH_SUBS_PATH=./push_subs.json
# Hashed, expiring clip-share grants and the once-per-day digest ledger.
CLIP_SHARES_PATH=./clip_shares.json
DIGEST_STATE_PATH=./daily_digest_state.json

# User-tunable detection knobs (threshold, cooldown, schedule, classes).
# Same volume as push_subs / VAPID — `docker compose up --build` won't
# wipe these.
DETECTION_CONFIG_PATH=./detection_config.json

# MediaMTX (informational; client connects directly to :8889)
MEDIAMTX_WHEP_BASE=http://localhost:8889

# iter-178: auth foundation. These are inert until Auth Plan Phase 3
# wires the /api/auth/* routes that consume them. Paths default to the
# same `homecam-secrets` Docker volume as VAPID + push_subs.
USERS_DB_PATH=./users.db
JWT_SECRET_PATH=./jwt_secret.bin
ACCESS_TOKEN_TTL_S=900
REFRESH_TOKEN_TTL_S=604800
# Set to false in dev (vite at http://localhost:5173, no TLS); leave
# true in prod once Caddy/Tailscale fronts the server with TLS.
COOKIE_SECURE=true

# iter-179: First-boot admin seed. Both must be set together for
# the lifespan bootstrap to fire; if the users table is non-empty
# at boot, these are ignored. The HASH is argon2id, pre-computed —
# get one via `python -m app.scripts.gen_admin <user>` (interactive)
# OR `python -c "from app.auth.passwords import hash_password; print(hash_password('your-password'))"`.
# DO NOT put plaintext here.
HOMECAM_ADMIN_USER=
HOMECAM_ADMIN_PASSWORD_HASH=

# iter-212 (Feature #10 slice 3): on-disk dir that backup archives
# land in. /api/system/backup writes here (slice 4 host-helper),
# /api/system/restore reads from here. The route validates the
# backup_path body parameter resolves to a path UNDER this dir —
# defense against `../../etc/passwd` traversal. Production should
# mount a USB drive / NAS share at this path.
BACKUP_TARGET_DIR=./backups
BACKUP_LEDGER_PATH=/app/secrets/backup-ledger.jsonl

# iter-232 (Feature #12 OTA slice 3a): hand-bumped server version
# string. The default lives in config.py; this lets operators
# override at deploy time (e.g. CI sets HOMECAM_VERSION=$(git describe)
# without rebuilding the image). Surfaced via GET /api/system/version
# so the iter-233 client UI can display "Server version: <x>".
HOMECAM_VERSION=0.1.0

# iter-213 (Feature #8 slice 1): dir for daily-timelapse MP4 files
# generated by the host-side ffmpeg helper (slice 2 — operator
# action). Mounted at /timelapses by main.py (same StaticFiles
# pattern as SNAPSHOTS_DIR). Files are `<YYYY-MM-DD>.mp4`.
TIMELAPSES_DIR=./timelapses

# iter-351 (face-capture-for-retraining): dir the host-side detection
# worker saves face crops into via detection/face_recog/capture.py.
# Per-name subdirs (alice/, sheenal/, __unknown__/, ...) capped at 200
# entries each via LRU eviction. Container server reads via the auth-
# gated GET /api/face/captures route. See detection/face_recog/
# README_TRAINING.md for the operator workflow.
FACE_CAPTURES_DIR=./face_captures

# iter-356.62 (tiered-capture slices 1-3): parallel root for full-person
# crops the worker saves alongside each face crop. NOT a subdir of
# FACE_CAPTURES_DIR — the existing /face/captures listing route would
# treat a nested _person subtree as a name bucket. Read by
# /api/training/export when kind=person; swept by face_capture_sweeper.
PERSON_CAPTURES_DIR=./person_captures

# iter-216 (Feature #6 slice 1): SQLite-backed event store. iter-216
# ships the schema only; slice 2 wires writes alongside the existing
# in-memory deque, slice 3 swaps reads, slice 4 adds the search
# route + calendar UI. Same secrets-volume placement convention as
# USERS_DB_PATH / VAPID keys / PUSH_SUBS_PATH.
EVENTS_DB_PATH=./events.db

# Operator audit trail for auth/session events and client view telemetry.
# Stored separately from camera events because it records user behavior.
AUDIT_DB_PATH=/app/secrets/audit.db

# Logged-in sessions store (slice C): tracks live sessions by jti for the
# god-mode Sessions view + remote revocation. Separate 0600 SQLite file.
SESSIONS_DB_PATH=/app/secrets/sessions.db

# Manual host-recovery request store (slice D): the persisted request/ack/result
# record the server writes and the detection worker polls (mediamtx/nvargus/reboot).
HOST_ACTION_STATE_PATH=/app/secrets/host_action.json

# Desired auto-exposure metering region and compensation. Stored in the
# persistent secrets volume; the host worker applies it to nvarguscamerasrc.
CAMERA_EXPOSURE_PATH=/app/secrets/camera_exposure.json

# Private security-platform state and generated timeline/evidence files.
SECURITY_STATE_PATH=/app/secrets/security-state.json
SECURITY_EXPORTS_DIR=/app/secrets/security-exports
# Listing allows a full local day; video export stays bounded to six hours.
SECURITY_TIMELINE_MAX_RANGE_S=86400
SECURITY_TIMELINE_EXPORT_MAX_RANGE_S=21600
# Export capacity guardrails. Pending/running jobs reserve their selected
# segment bytes before ffmpeg starts; ready files count until 24h expiry.
SECURITY_EXPORT_MAX_OUTSTANDING_JOBS=2
SECURITY_EXPORT_MAX_TOTAL_BYTES=5368709120
SECURITY_EXPORT_MIN_FREE_BYTES=4294967296
# MediaMTX runs on the host while FastAPI runs in Docker. Trust only the exact
# observed host-to-container bridge gateway plus loopback; never a whole CIDR.
MEDIAMTX_AUTH_TRUSTED_CALLERS=127.0.0.1,::1,172.18.0.1
AUTOMATION_WEBHOOK_TIMEOUT_S=5
# Optional MQTT adapter. Credentials remain environment-only.
HOMECAM_MQTT_HOST=
HOMECAM_MQTT_PORT=1883
HOMECAM_MQTT_USERNAME=
HOMECAM_MQTT_PASSWORD=
# Optional mounted executable adapter; unavailable by default in Docker.
HOMECAM_DETERRENCE_DRIVER=

# --- OTA update flow (harness #11; strategy: rsync artifact bundle) ---
# All default under the persistent secrets volume so update state survives
# container recreation. Operator rsyncs artifacts to OTA_ARTIFACTS_DIR.
OTA_ROOT=/app/secrets/dist-ota
OTA_MANIFEST_PATH=/app/secrets/dist-ota/update-manifest.json
OTA_ARTIFACTS_DIR=/app/secrets/dist-ota/artifacts
OTA_STAGING_ROOT=/app/secrets/dist-ota/staging
OTA_ACTIVE_POINTER=/app/secrets/dist-ota/active.json
OTA_LEDGER_PATH=/app/secrets/dist-ota/update-ledger.jsonl
# In-container mount of host ~/HomeCameraSystem/client/dist. OTA can only
# replace this served client bundle directly; detection/image updates are
# recorded as host commands for the operator/host helper.
OTA_CLIENT_DIST_TARGET=/app/client_dist
# Recorded (not executed) by the restart seam; operator wires the real one.
OTA_RESTART_COMMAND=docker restart homecam-server
