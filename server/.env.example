# Server bind
HOST=0.0.0.0
PORT=8000

# VAPID keys (generated by `python -m app.scripts.gen_vapid`)
VAPID_PRIVATE_KEY_PATH=./vapid_private.pem
VAPID_PUBLIC_KEY_PATH=./vapid_public.pem
VAPID_SUBJECT=mailto:admin@example.com

# Camera
CAMERA_DEVICE=/dev/video0

# Compiled client to serve as SPA (relative to server/ working dir)
CLIENT_DIST=../client/dist

# Snapshot output
SNAPSHOTS_DIR=./snapshots

# iter-201 (Feature #1 Event clip recording): on-disk dir for per-
# event MP4 clips written by the host-side recorder (slice 2).
# Bind-mounted similarly to SNAPSHOTS_DIR so the host writes /
# the container reads. The iter-201 sweeper deletes clips older
# than RECORDINGS_RETENTION_DAYS; default 14 days. Set to 0 to
# disable the sweeper (operator manages retention manually).
RECORDINGS_DIR=./recordings
RECORDINGS_RETENTION_DAYS=14

# Persisted Web Push subscriptions. In production this lives on the
# `homecam-secrets` Docker volume so it survives container rebuilds.
PUSH_SUBS_PATH=./push_subs.json

# User-tunable detection knobs (threshold, cooldown, schedule, classes).
# Same volume as push_subs / VAPID — `docker compose up --build` won't
# wipe these.
DETECTION_CONFIG_PATH=./detection_config.json

# MediaMTX (informational; client connects directly to :8889)
MEDIAMTX_WHEP_BASE=http://localhost:8889

# iter-178: auth foundation. These are inert until Auth Plan Phase 3
# wires the /api/auth/* routes that consume them. Paths default to the
# same `homecam-secrets` Docker volume as VAPID + push_subs.
USERS_DB_PATH=./users.db
JWT_SECRET_PATH=./jwt_secret.bin
ACCESS_TOKEN_TTL_S=900
REFRESH_TOKEN_TTL_S=604800
# Set to false in dev (vite at http://localhost:5173, no TLS); leave
# true in prod once Caddy/Tailscale fronts the server with TLS.
COOKIE_SECURE=true

# iter-179: First-boot admin seed. Both must be set together for
# the lifespan bootstrap to fire; if the users table is non-empty
# at boot, these are ignored. The HASH is argon2id, pre-computed —
# get one via `python -m app.scripts.gen_admin <user>` (interactive)
# OR `python -c "from app.auth.passwords import hash_password; print(hash_password('your-password'))"`.
# DO NOT put plaintext here.
HOMECAM_ADMIN_USER=
HOMECAM_ADMIN_PASSWORD_HASH=

# iter-212 (Feature #10 slice 3): on-disk dir that backup archives
# land in. /api/system/backup writes here (slice 4 host-helper),
# /api/system/restore reads from here. The route validates the
# backup_path body parameter resolves to a path UNDER this dir —
# defense against `../../etc/passwd` traversal. Production should
# mount a USB drive / NAS share at this path.
BACKUP_TARGET_DIR=./backups

# iter-232 (Feature #12 OTA slice 3a): hand-bumped server version
# string. The default lives in config.py; this lets operators
# override at deploy time (e.g. CI sets HOMECAM_VERSION=$(git describe)
# without rebuilding the image). Surfaced via GET /api/system/version
# so the iter-233 client UI can display "Server version: <x>".
HOMECAM_VERSION=0.1.0

# iter-213 (Feature #8 slice 1): dir for daily-timelapse MP4 files
# generated by the host-side ffmpeg helper (slice 2 — operator
# action). Mounted at /timelapses by main.py (same StaticFiles
# pattern as SNAPSHOTS_DIR). Files are `<YYYY-MM-DD>.mp4`.
TIMELAPSES_DIR=./timelapses

# iter-351 (face-capture-for-retraining): dir the host-side detection
# worker saves face crops into via detection/face_recog/capture.py.
# Per-name subdirs (alice/, sheenal/, __unknown__/, ...) capped at 200
# entries each via LRU eviction. Container server reads via the auth-
# gated GET /api/face/captures route. See detection/face_recog/
# README_TRAINING.md for the operator workflow.
FACE_CAPTURES_DIR=./face_captures

# iter-216 (Feature #6 slice 1): SQLite-backed event store. iter-216
# ships the schema only; slice 2 wires writes alongside the existing
# in-memory deque, slice 3 swaps reads, slice 4 adds the search
# route + calendar UI. Same secrets-volume placement convention as
# USERS_DB_PATH / VAPID keys / PUSH_SUBS_PATH.
EVENTS_DB_PATH=./events.db
